/*-----QmayaSeparator------------------------------------------------------------------------------------------------------------------------------------*/       
QmayaSeparator { background-color: rgb(41,41,41); }


/*-----QFileDialog------------------------------------------------------------------------------------------------------------------------------------*/ 
QFileDialog { background-color: rgb(41,41,41); } 


/*-----QStatusBar------------------------------------------------------------------------------------------------------------------------------------*/ 
QStatusBar { background: transparent; }



